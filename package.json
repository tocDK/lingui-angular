{
  "name": "@tocdk/lingui-angular",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "description": "Angular 20+ bindings for Lingui — write English, extract via AST, ship PO catalogs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tocDK/lingui-angular.git"
  },
  "homepage": "https://github.com/tocDK/lingui-angular",
  "bugs": "https://github.com/tocDK/lingui-angular/issues",
  "exports": {
    ".": {
      "types": "./dist/lingui-angular/index.d.ts",
      "default": "./dist/lingui-angular/fesm2022/tocdk-lingui-angular.mjs"
    },
    "./extractor": {
      "types": "./dist/lingui-angular/extractor/index.d.ts",
      "default": "./dist/lingui-angular/extractor/index.mjs"
    }
  },
  "bin": {
    "lingui-angular": "./dist/lingui-angular/extractor/bin.mjs"
  },
  "files": [
    "dist/",
    "scripts/",
    "projects/lingui-angular/extractor/tsconfig.build.json",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "chokidar": "^4.0.3"
  },
  "scripts": {
    "ng": "ng",
    "prepare": "if [ -z \"$CI\" ] && [ -d projects/lingui-angular ]; then npm run build:lib; fi",
    "start": "ng serve kitchen-sink",
    "build": "npm run build:lib && npm run build:demo",
    "build:lib": "ng build lingui-angular --configuration=production && node scripts/build-extractor.mjs",
    "build:demo": "ng build kitchen-sink --configuration=production",
    "build:demo:ssr": "ng build kitchen-sink --configuration=production --ssr",
    "watch:lib": "ng build lingui-angular --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:lib": "vitest run --project lib",
    "test:extractor": "vitest run --project extractor",
    "test:ssr": "vitest run --project ssr",
    "lint": "eslint \"projects/**/*.ts\" \"projects/**/*.html\"",
    "extract": "tsx projects/lingui-angular/extractor/bin.ts extract && lingui extract && tsx projects/lingui-angular/extractor/bin.ts clean",
    "extract:watch": "tsx projects/lingui-angular/extractor/bin.ts extract --watch & lingui extract --watch",
    "extract:check": "lingui compile --typescript && git diff --exit-code projects/kitchen-sink/src/locales"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^1.22.5",
    "@analogjs/vitest-angular": "^1.22.5",
    "@angular/animations": "^20.3.23",
    "@angular/build": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/common": "^20.3.23",
    "@angular/compiler": "^20.3.23",
    "@angular/compiler-cli": "^20.3.23",
    "@angular/core": "^20.3.23",
    "@angular/forms": "^20.3.23",
    "@angular/platform-browser": "^20.3.23",
    "@angular/platform-server": "^20.3.23",
    "@angular/router": "^20.3.23",
    "@angular/ssr": "^20.3.26",
    "@lingui/cli": "^6.1.0",
    "@lingui/core": "^6.1.0",
    "@lingui/format-po": "^6.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.19",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "ng-packagr": "^20.3.2",
    "prettier": "^3.8.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.0",
    "vitest": "^3.2.6",
    "zone.js": "^0.15.1"
  }
}
